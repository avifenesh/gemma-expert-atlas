{
  "name": "gemma-expert-atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "inspect": "python3 scripts/inspect_gemma4_moe.py --model-dir /data/ai-ml/hf-models/gemma4-26ba4b-base --out public/data/expert_manifest.json",
    "make-corpus": "python3 scripts/make_calibration_corpus.py --mode mixed --out data/calibration_mixed.txt",
    "make-reasoning-corpora": "python3 scripts/make_calibration_corpus.py --mode reasoning_off --out data/calibration_reasoning_off.txt && python3 scripts/make_calibration_corpus.py --mode reasoning_on --out data/calibration_reasoning_on.txt",
    "make-theme-corpora": "python3 scripts/make_theme_corpora.py",
    "calibrate": "scripts/run_routing_calibration.sh",
    "calibrate:all": "scripts/run_all_calibrations.sh",
    "calibrate:themes": "scripts/run_theme_calibrations.sh",
    "make-kv-cache-eval": "python3 scripts/make_kv_cache_eval.py",
    "eval:kv-cache": "python3 scripts/run_kv_cache_eval.py",
    "make-personal-agent-eval": "python3 scripts/make_personal_agent_eval.py",
    "eval:personal-agent": "python3 scripts/run_kv_cache_eval.py --tasks data/personal_agent_eval/tasks.jsonl --runs-dir data/personal_agent_eval/runs --reasoning on",
    "eval:personal-agent:both": "python3 scripts/run_kv_cache_eval.py --tasks data/personal_agent_eval/tasks.jsonl --runs-dir data/personal_agent_eval/runs --reasoning-sweep on,off",
    "make-personal-agent-bank": "python3 scripts/make_personal_agent_bank.py",
    "make-personal-agent-corpora": "python3 scripts/make_personal_agent_corpora.py",
    "eval:personal-agent-bank": "python3 scripts/run_kv_cache_eval.py --tasks data/personal_agent_bank/tasks.jsonl --runs-dir data/personal_agent_bank/runs --reasoning on",
    "eval:personal-agent-bank:both": "python3 scripts/run_kv_cache_eval.py --tasks data/personal_agent_bank/tasks.jsonl --runs-dir data/personal_agent_bank/runs --reasoning-sweep on,off",
    "calibrate:personal-agent": "scripts/run_personal_agent_calibrations.sh",
    "analyze:experts": "python3 scripts/analyze_expert_usage.py",
    "plan:surgery": "python3 scripts/plan_expert_surgery.py",
    "plan:runtime-eviction": "python3 scripts/plan_runtime_eviction.py --probe-name runtime_evict_after_prefix_v0 --candidate-file data/surgery_experiments/runtime_evict_after_prefix_v0.txt",
    "plan:combined-static": "python3 scripts/plan_runtime_eviction.py --include-never-active --probe-name combined_early_then_silent_plus_never_active_v0 --probe-kind combined_layer_specific_static_mask --out data/surgery_experiments/combined_static_mask_plan.json --candidate-file data/surgery_experiments/combined_early_then_silent_plus_never_active_v0.txt",
    "plan:incremental-ladder": "python3 scripts/plan_incremental_ladder.py",
    "score:merge-weights": "python3 scripts/score_expert_merge_weights.py",
    "report:trim": "python3 scripts/make_trim_decision_report.py",
    "report:eval-category": "python3 scripts/summarize_eval_by_category.py",
    "sanitize:public-data": "python3 scripts/sanitize_public_data.py",
    "mask:trim-probe": "python3 scripts/mask_gguf_experts.py --stage trim_probe_zero_all_v0",
    "mask:runtime-evict-static": "python3 scripts/mask_gguf_experts.py --stage runtime_evict_after_prefix_v0 --expert-file data/surgery_experiments/runtime_evict_after_prefix_v0.txt",
    "mask:combined-static": "python3 scripts/mask_gguf_experts.py --stage combined_early_then_silent_plus_never_active_v0 --expert-file data/surgery_experiments/combined_early_then_silent_plus_never_active_v0.txt",
    "replace:expert": "python3 scripts/replace_gguf_expert.py",
    "blend:hf-expert": "python3 scripts/blend_hf_expert.py",
    "trim:global-probe": "python3 scripts/trim_gguf_global_experts.py --expert-index 116",
    "timeline:routing": "python3 scripts/run_routing_timeline.py",
    "timeline:personal-agent": "scripts/run_personal_agent_timelines.sh",
    "timeline:combine": "python3 scripts/combine_routing_timelines.py",
    "pipeline:surgery": "scripts/run_expert_surgery_pipeline.sh",
    "import-routing": "python3 scripts/import_imatrix_counts.py --label mixed --imatrix data/routing-imatrix.gguf --out public/data/routing_trace.json",
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "playwright": "^1.61.0"
  }
}
